# LM Studio Configuration
# ========================

# LM Studio API URL (default: http://localhost:1234)
# Leave empty to use default
LM_STUDIO_API_URL=http://localhost:1234

# Optional: LM Studio API Token (if your LM Studio instance requires authentication)
# Get this from your LM Studio settings > API settings
LM_STUDIO_API_TOKEN=

# Backend Server Configuration
BACKEND_HOST=localhost
BACKEND_PORT=3000

# Optional: Client Identifier (for tracking requests in LM Studio)
CLIENT_IDENTIFIER=

# Optional: Client Passkey (if needed for your setup)
CLIENT_PASSKEY=

# Enable verbose error messages for debugging
VERBOSE_ERRORS=false
