# LM Studio Configuration
# ========================

# LM Studio API URL (default: http://localhost:1234)
LM_STUDIO_BASE_URL=http://localhost:1234

# IMPORTANT: If LM Studio has authentication enabled, you have two options:
# Option 1 (RECOMMENDED): Disable authentication in LM Studio
#   - Open LM Studio > Settings > Server > Security
#   - Toggle off "Require authentication"
#   - Restart LM Studio
# 
# Option 2: Provide valid credentials below
# Currently these options are not supported by @lmstudio/sdk
# CLIENT_IDENTIFIER=your-identifier
# CLIENT_PASSKEY=your-passkey

# Backend Server Configuration
HOST=127.0.0.1
PORT=3000

# Enable verbose error messages for debugging
VERBOSE_ERRORS=true
