{
  "name": "x-dev-lm-studio",
  "version": "1.0.0",
  "description": "Local LLM server and agent framework using LM Studio SDK",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.backend.json",
    "dev": "tsc -p tsconfig.backend.json --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "llm",
    "lm-studio",
    "local-ai",
    "typescript"
  ],
  "author": "X-DEV",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@lmstudio/sdk": "latest"
  }
}
